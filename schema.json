{
  "Capture": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "kind": {
        "type": "string",
        "enum": [
          "site_photo",
          "drawing_sheet"
        ]
      },
      "source": {
        "type": "string"
      },
      "uri": {
        "type": "string"
      },
      "building": {
        "type": "string"
      },
      "sheetNumber": {
        "default": null,
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      },
      "discipline": {
        "default": null,
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      },
      "titleblockBox": {
        "default": null,
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              },
              "w": {
                "type": "number"
              },
              "h": {
                "type": "number"
              }
            },
            "required": [
              "x",
              "y",
              "w",
              "h"
            ],
            "additionalProperties": false
          },
          {
            "type": "null"
          }
        ]
      },
      "offlineCached": {
        "default": false,
        "type": "boolean"
      },
      "capturedAt": {
        "type": "string"
      },
      "author": {
        "type": "string"
      }
    },
    "required": [
      "id",
      "kind",
      "source",
      "uri",
      "building",
      "sheetNumber",
      "discipline",
      "titleblockBox",
      "offlineCached",
      "capturedAt",
      "author"
    ],
    "additionalProperties": false
  },
  "ReferencePoint": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "captureId": {
        "type": "string"
      },
      "n": {
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      },
      "x": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "y": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "coordSpace": {
        "type": "string",
        "enum": [
          "image",
          "titleblock_normalized"
        ]
      },
      "label": {
        "default": null,
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "required": [
      "id",
      "captureId",
      "n",
      "x",
      "y",
      "coordSpace",
      "label"
    ],
    "additionalProperties": false
  },
  "Note": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "text": {
        "type": "string",
        "minLength": 1
      },
      "inputMode": {
        "type": "string",
        "enum": [
          "voice",
          "text"
        ]
      },
      "referencePointId": {
        "default": null,
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      },
      "reportId": {
        "type": "string"
      },
      "createdAt": {
        "type": "string"
      }
    },
    "required": [
      "id",
      "text",
      "inputMode",
      "referencePointId",
      "reportId",
      "createdAt"
    ],
    "additionalProperties": false
  },
  "System": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "discipline": {
        "type": "string",
        "enum": [
          "Architectural",
          "Structural",
          "Mechanical",
          "Electrical",
          "Low voltage",
          "Controls",
          "Fire/Life-safety"
        ]
      },
      "building": {
        "type": "string"
      }
    },
    "required": [
      "id",
      "name",
      "discipline",
      "building"
    ],
    "additionalProperties": false
  },
  "CommissioningRecord": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "systemId": {
        "type": "string"
      },
      "building": {
        "type": "string"
      },
      "level": {
        "anyOf": [
          {
            "type": "number",
            "const": 0
          },
          {
            "type": "number",
            "const": 1
          },
          {
            "type": "number",
            "const": 2
          },
          {
            "type": "number",
            "const": 3
          },
          {
            "type": "number",
            "const": 4
          },
          {
            "type": "number",
            "const": 5
          }
        ]
      },
      "tag": {
        "type": "string",
        "enum": [
          "none",
          "red",
          "yellow",
          "green",
          "blue",
          "white"
        ]
      },
      "plannedLevelForPeriod": {
        "anyOf": [
          {
            "type": "number",
            "const": 0
          },
          {
            "type": "number",
            "const": 1
          },
          {
            "type": "number",
            "const": 2
          },
          {
            "type": "number",
            "const": 3
          },
          {
            "type": "number",
            "const": 4
          },
          {
            "type": "number",
            "const": 5
          }
        ]
      },
      "testDate": {
        "default": null,
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      },
      "signoffs": {
        "default": [],
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "by": {
              "type": "string"
            },
            "role": {
              "type": "string"
            },
            "at": {
              "type": "string"
            }
          },
          "required": [
            "by",
            "role",
            "at"
          ],
          "additionalProperties": false
        }
      },
      "openPunchIds": {
        "default": [],
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
      "id",
      "systemId",
      "building",
      "level",
      "tag",
      "plannedLevelForPeriod",
      "testDate",
      "signoffs",
      "openPunchIds"
    ],
    "additionalProperties": false
  },
  "ScheduleActivity": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "systemId": {
        "type": "string"
      },
      "building": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "plannedFinish": {
        "type": "number"
      },
      "forecastFinish": {
        "type": "number"
      },
      "pct": {
        "type": "number",
        "minimum": 0,
        "maximum": 100
      },
      "critical": {
        "default": false,
        "type": "boolean"
      },
      "gatingId": {
        "default": null,
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "required": [
      "id",
      "systemId",
      "building",
      "name",
      "plannedFinish",
      "forecastFinish",
      "pct",
      "critical",
      "gatingId"
    ],
    "additionalProperties": false
  },
  "MassingModel": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "building": {
        "type": "string"
      },
      "levels": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "footprint": {
              "minItems": 3,
              "type": "array",
              "items": {
                "type": "array",
                "prefixItems": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  }
                ]
              }
            },
            "floorToFloor": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "confirmedBy": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "footprint",
            "floorToFloor",
            "confirmedBy"
          ],
          "additionalProperties": false
        }
      },
      "statusOverlays": {
        "default": [],
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "systemId": {
              "type": "string"
            },
            "levelName": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "on_track",
                "at_risk",
                "behind"
              ]
            }
          },
          "required": [
            "systemId",
            "levelName",
            "status"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "id",
      "building",
      "levels",
      "statusOverlays"
    ],
    "additionalProperties": false
  },
  "DerivedReportSnapshot": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "reportId": {
        "type": "string"
      },
      "cadence": {
        "type": "string",
        "enum": [
          "Daily",
          "Weekly",
          "Monthly",
          "Quarterly",
          "OnDemand"
        ]
      },
      "period": {
        "type": "string"
      },
      "building": {
        "type": "string"
      },
      "computedValues": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      },
      "sourceReportIds": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "narrativeEdits": {
        "default": [],
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "field": {
              "type": "string"
            },
            "text": {
              "type": "string"
            }
          },
          "required": [
            "field",
            "text"
          ],
          "additionalProperties": false
        }
      },
      "numberOverrides": {
        "default": [],
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "field": {
              "type": "string"
            },
            "value": {},
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "by": {
              "type": "string"
            }
          },
          "required": [
            "field",
            "value",
            "reason",
            "by"
          ],
          "additionalProperties": false
        }
      },
      "approvedBy": {
        "type": "string"
      },
      "approvedAt": {
        "type": "string"
      },
      "version": {
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      }
    },
    "required": [
      "reportId",
      "cadence",
      "period",
      "building",
      "computedValues",
      "sourceReportIds",
      "narrativeEdits",
      "numberOverrides",
      "approvedBy",
      "approvedAt",
      "version"
    ],
    "additionalProperties": false
  }
}